generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 공통 Enum ────────────────────────────────────────────────

enum UserType {
  customer
  freelancer
  admin
}

enum FreelancerStatus {
  draft
  pending_review
  approved
  rejected
  hidden
  suspended
}

enum RequestStatus {
  submitted
  reviewing
  recommending
  recommended
  consulting
  booked
  completed
  reviewed
  canceled
  disputed
}

enum RecommendationStatus {
  draft
  sent
  viewed
  consultation_requested
  selected
  rejected
}

enum QuoteStatus {
  proposed
  accepted
  rejected
  expired
  canceled
}

enum BookingStatus {
  pending
  negotiating
  accepted
  rejected
  payment_pending
  confirmed
  completion_requested
  completed
  canceled
  disputed
}

enum PaymentStatus {
  unpaid
  deposit_paid
  fully_paid
  refunded
  failed
}

enum SettlementStatus {
  pending
  scheduled
  completed
  held
  failed
}

enum ReviewStatus {
  pending
  published
  hidden
  reported
}

// 에스크로 상태: 결제 완료 후 대금 흐름
enum EscrowStatus {
  none       // 결제 전 / 불필요한 예약
  held       // 에스크로 보관 중 (결제 완료 → 행사 전)
  released   // 프리랜서에게 정산 완료
  refunded   // 환불 처리 완료
}

// 계약서 상태
enum ContractStatus {
  draft             // 자동 생성, 서명 전
  pending_customer  // 고객 서명 대기
  pending_freelancer // 프리랜서 서명 대기
  fully_signed      // 양측 서명 완료
  voided            // 무효 (예약 취소 등)
}

// ─── 모델 ────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  user_type     UserType
  name          String
  email         String   @unique
  password_hash String
  phone         String?
  provider      String?   // "kakao" | "google" | null(이메일)
  provider_id   String?   // OAuth provider의 고유 user id
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  customer_profile        CustomerProfile?
  freelancer_profile      FreelancerProfile?
  event_requests          EventRequest[]
  recommendations         Recommendation[]   @relation("RecommendedBy")
  quotes                  Quote[]            @relation("QuotedBy")
  bookings_as_customer    Booking[]          @relation("CustomerBookings")
  reviews_written         Review[]           @relation("CustomerReviews")
  freelancer_reviews_recv FreelancerReview[] @relation("CustomerFreelancerReviews")
  notifications           Notification[]
  chat_rooms_as_customer  ChatRoom[]         @relation("CustomerChatRooms")
  sent_chat_messages      ChatMessage[]      @relation("SentChatMessages")
  sent_booking_offers     BookingOffer[]     @relation("SentBookingOffers")
  received_booking_offers BookingOffer[]     @relation("ReceivedBookingOffers")
  refresh_tokens          RefreshToken[]
  saved_freelancers       SavedFreelancer[]  @relation("CustomerSavedFreelancers")

  @@index([email])
  @@index([user_type])
  @@index([provider, provider_id])
  @@map("users")
}

model CustomerProfile {
  id             String   @id @default(cuid())
  user_id        String   @unique
  customer_type  String?
  company_name   String?
  department     String?
  manager_name   String?
  memo           String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model FreelancerProfile {
  id                       String           @id @default(cuid())
  user_id                  String           @unique
  display_name             String?
  profile_image_url        String?
  profile_image_path       String?
  headline                 String?
  bio                      String?
  region                   String?
  available_regions        String[]         @default([])
  categories               String[]         @default([])
  styles                   String[]         @default([])
  career_years             Int?
  base_price_min           Int?
  base_price_max           Int?
  languages                String[]         @default([])
  script_writing_available Boolean          @default(false)
  rehearsal_available      Boolean          @default(false)
  travel_available         Boolean          @default(false)
  status                   FreelancerStatus @default(draft)
  voice_score              Float?
  approved_at              DateTime?
  rejected_reason          String?
  avg_rating               Float?
  review_count             Int              @default(0)
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  portfolios      Portfolio[]
  recommendations Recommendation[]
  quotes          Quote[]
  bookings        Booking[]         @relation("FreelancerBookings")
  chat_rooms      ChatRoom[]        @relation("FreelancerChatRooms")
  reviews         Review[]          @relation("FreelancerReviews")
  freelancer_reviews_written FreelancerReview[] @relation("FreelancerFreelancerReviews")
  saved_by               SavedFreelancer[]  @relation("SavedByCustomers")

  @@index([status])
  @@map("freelancer_profiles")
}

model Portfolio {
  id                String   @id @default(cuid())
  freelancer_id     String
  portfolio_type    String
  title             String
  description       String?
  media_url         String
  thumbnail_url     String?
  category          String?
  is_representative Boolean  @default(false)
  is_public         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  freelancer FreelancerProfile @relation(fields: [freelancer_id], references: [id], onDelete: Cascade)

  @@index([freelancer_id])
  @@map("portfolios")
}

model EventRequest {
  id                        String        @id @default(cuid())
  customer_id               String
  event_title               String
  event_type                String
  event_date                DateTime
  start_time                String
  end_time                  String
  region                    String
  venue                     String?
  budget_min                Int?
  budget_max                Int?
  preferred_freelancer_type String[]      @default([])
  preferred_styles          String[]      @default([])
  required_language         String?
  script_required           Boolean       @default(false)
  rehearsal_required        Boolean       @default(false)
  travel_required           Boolean       @default(false)
  attachment_url            String?
  description               String?
  status                    RequestStatus @default(submitted)
  created_at                DateTime      @default(now())
  updated_at                DateTime      @updatedAt

  customer        User             @relation(fields: [customer_id], references: [id])
  recommendations Recommendation[]
  quotes          Quote[]
  bookings        Booking[]

  @@index([customer_id])
  @@index([status])
  @@map("event_requests")
}

model Recommendation {
  id                    String               @id @default(cuid())
  request_id            String
  freelancer_id         String
  recommended_by        String
  recommendation_reason String?
  display_order         Int                  @default(0)
  status                RecommendationStatus @default(draft)
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  request    EventRequest      @relation(fields: [request_id], references: [id])
  freelancer FreelancerProfile @relation(fields: [freelancer_id], references: [id])
  admin      User              @relation("RecommendedBy", fields: [recommended_by], references: [id])

  @@index([request_id])
  @@unique([request_id, freelancer_id])
  @@map("recommendations")
}

model Quote {
  id                   String      @id @default(cuid())
  request_id           String
  freelancer_id        String
  quoted_by            String
  price                Int
  platform_fee         Int         @default(0)
  total_price          Int
  included_services    String?
  script_included      Boolean     @default(false)
  rehearsal_included   Boolean     @default(false)
  travel_fee_included  Boolean     @default(false)
  message              String?
  valid_until          DateTime?
  status               QuoteStatus @default(proposed)
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  request        EventRequest      @relation(fields: [request_id], references: [id])
  freelancer     FreelancerProfile @relation(fields: [freelancer_id], references: [id])
  quoted_by_user User              @relation("QuotedBy", fields: [quoted_by], references: [id])
  bookings       Booking[]

  @@index([request_id])
  @@index([freelancer_id])
  @@map("quotes")
}

model Booking {
  id                 String          @id @default(cuid())
  request_id         String?
  customer_id        String
  freelancer_id      String
  quote_id           String?
  event_title        String
  event_date         DateTime
  start_time         String
  end_time           String
  venue              String?
  final_price        Int
  platform_fee       Int             @default(0)
  freelancer_amount  Int
  booking_status     BookingStatus   @default(pending)
  payment_status     PaymentStatus   @default(unpaid)
  settlement_status  SettlementStatus @default(pending)
  escrow_status      EscrowStatus    @default(none)
  escrow_held_at              DateTime?
  escrow_released_at          DateTime?
  completion_requested_at     DateTime?
  cancel_reason      String?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  request    EventRequest?     @relation(fields: [request_id], references: [id])
  customer   User              @relation("CustomerBookings", fields: [customer_id], references: [id])
  freelancer FreelancerProfile @relation("FreelancerBookings", fields: [freelancer_id], references: [id])
  quote      Quote?            @relation(fields: [quote_id], references: [id])
  reviews    Review[]
  payment    Payment?
  chat_room  ChatRoom?
  offers     BookingOffer[]
  contract   Contract?
  freelancer_reviews FreelancerReview[]

  @@index([customer_id])
  @@index([freelancer_id])
  @@index([booking_status])
  @@index([payment_status])
  @@index([escrow_status])
  @@map("bookings")
}

// ─── 계약서 ─────────────────────────────────────────────────

model Contract {
  id                       String         @id @default(cuid())
  booking_id               String         @unique
  // 계약 내용을 JSON으로 저장 (당사자 정보, 행사 내용, 금액, 조건 등)
  content_json             Json
  status                   ContractStatus @default(draft)
  // 고객 서명
  customer_signed_at       DateTime?
  customer_signature_hash  String?        // SHA256(user_id + booking_id + timestamp)
  // 프리랜서 서명
  freelancer_signed_at     DateTime?
  freelancer_signature_hash String?
  // 완전 서명 완료 시각
  fully_signed_at          DateTime?
  created_at               DateTime       @default(now())
  updated_at               DateTime       @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([booking_id])
  @@map("contracts")
}

// ─── 프리랜서 → 의뢰인 리뷰 ─────────────────────────────────

model FreelancerReview {
  id                     String       @id @default(cuid())
  booking_id             String       @unique
  freelancer_id          String       // 리뷰 작성자 (프리랜서 프로필 ID)
  customer_id            String       // 리뷰 대상자 (유저 ID)
  professionalism_score  Int          // 전문성 (1-5)
  communication_score    Int          // 소통 (1-5)
  payment_promptness_score Int        // 결제 신속성 (1-5)
  respect_score          Int          // 예의·존중 (1-5)
  total_score            Float
  would_work_again       Boolean
  comment                String?
  status                 ReviewStatus @default(pending)
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt

  booking    Booking           @relation(fields: [booking_id], references: [id])
  freelancer FreelancerProfile @relation("FreelancerFreelancerReviews", fields: [freelancer_id], references: [id])
  customer   User              @relation("CustomerFreelancerReviews", fields: [customer_id], references: [id])

  @@index([freelancer_id])
  @@index([customer_id])
  @@map("freelancer_reviews")
}

// ─── 알림 ────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  user_id    String
  type       String
  title      String
  message    String
  link_url   String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read, created_at])
  @@map("notifications")
}

// ─── 채팅 ────────────────────────────────────────────────────

model ChatRoom {
  id              String    @id @default(cuid())
  booking_id      String    @unique
  customer_id     String
  freelancer_id   String
  last_message_at DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  booking    Booking           @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  customer   User              @relation("CustomerChatRooms", fields: [customer_id], references: [id])
  freelancer FreelancerProfile @relation("FreelancerChatRooms", fields: [freelancer_id], references: [id])
  messages   ChatMessage[]

  @@index([customer_id])
  @@index([freelancer_id])
  @@index([last_message_at])
  @@map("chat_rooms")
}

model ChatMessage {
  id           String   @id @default(cuid())
  room_id      String
  sender_id    String?
  message      String
  message_type String   @default("text")
  offer_id     String?
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())

  room   ChatRoom      @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender User?         @relation("SentChatMessages", fields: [sender_id], references: [id])
  offer  BookingOffer? @relation(fields: [offer_id], references: [id])

  @@index([room_id, created_at])
  @@index([sender_id])
  @@map("chat_messages")
}

model BookingOffer {
  id           String    @id @default(cuid())
  booking_id   String
  sender_id    String
  receiver_id  String
  amount       Int
  message      String?
  status       String    @default("pending")
  responded_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  booking       Booking       @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  sender        User          @relation("SentBookingOffers", fields: [sender_id], references: [id])
  receiver      User          @relation("ReceivedBookingOffers", fields: [receiver_id], references: [id])
  chat_messages ChatMessage[]

  @@index([booking_id, status])
  @@index([receiver_id, status])
  @@map("booking_offers")
}

// ─── 리뷰 (고객 → 프리랜서) ─────────────────────────────────

model Review {
  id                        String       @id @default(cuid())
  booking_id                String       @unique
  customer_id               String
  freelancer_id             String
  punctuality_score         Int
  voice_delivery_score      Int
  event_understanding_score Int
  atmosphere_score          Int
  script_score              Int
  response_score            Int
  communication_score       Int
  total_score               Float
  rehire_intent             Boolean
  comment                   String?
  status                    ReviewStatus @default(pending)
  created_at                DateTime     @default(now())
  updated_at                DateTime     @updatedAt

  booking    Booking           @relation(fields: [booking_id], references: [id])
  customer   User              @relation("CustomerReviews", fields: [customer_id], references: [id])
  freelancer FreelancerProfile @relation("FreelancerReviews", fields: [freelancer_id], references: [id])

  @@index([freelancer_id])
  @@index([status])
  @@map("reviews")
}

// ─── 인증 ────────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(cuid())
  user_id    String
  token_hash String
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

// ─── 결제 ────────────────────────────────────────────────────

model Payment {
  id              String            @id @default(cuid())
  booking_id      String            @unique
  order_id        String            @unique
  payment_key     String?           @unique
  amount          Int
  method          String?
  status          PaymentStatusToss @default(READY)
  requested_at    DateTime?
  approved_at     DateTime?
  failure_code    String?
  failure_message String?
  raw_response    Json?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id])

  @@index([booking_id])
  @@index([order_id])
  @@map("payments")
}

enum PaymentStatusToss {
  READY
  IN_PROGRESS
  WAITING_FOR_DEPOSIT
  DONE
  CANCELED
  PARTIAL_CANCELED
  ABORTED
  EXPIRED
}

model SavedFreelancer {
  id            String   @id @default(cuid())
  customer_id   String
  freelancer_id String
  created_at    DateTime @default(now())

  customer   User              @relation("CustomerSavedFreelancers", fields: [customer_id], references: [id], onDelete: Cascade)
  freelancer FreelancerProfile @relation("SavedByCustomers", fields: [freelancer_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, freelancer_id])
  @@index([customer_id])
  @@map("saved_freelancers")
}
