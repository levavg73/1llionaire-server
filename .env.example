# ─── 데이터베이스 ─────────────────────────────────────────────────────────────
# Render: 내부 PostgreSQL URL 사용 (Render 대시보드에서 복사)
# Supabase: Transaction Pooler URL (connection_limit=1 권장)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Prisma migrate/seed 전용 (Supabase Direct URL, Render는 불필요)
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# 최소 32자 이상 랜덤 문자열 (openssl rand -hex 32 로 생성)
JWT_SECRET="replace-with-at-least-32-chars-random-string"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── 서버 ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS / Origin ────────────────────────────────────────────────────────────
# 로컬 개발
CLIENT_URL=http://localhost:3000
# 프로덕션 Vercel URL (배포 후 입력)
CLIENT_URL_PROD=

# ─── 토스페이먼츠 ─────────────────────────────────────────────────────────────
# https://developers.tosspayments.com → 내 개발정보 → 테스트 키
# Sandbox: test_sk_... / test_ck_...
# Production: live_sk_... / live_ck_...
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Seed 전용 (배포 환경에서는 불필요) ──────────────────────────────────────
ADMIN_EMAIL=admin@freemic.co.kr
ADMIN_PASSWORD="replace-with-admin-password"
