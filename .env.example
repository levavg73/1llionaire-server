# ─── 데이터베이스 ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET="replace-with-at-least-32-chars-random-string"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── 서버 ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# CLIENT_URL: 로컬 프론트엔드 origin
# CLIENT_URL_PROD: 배포된 프론트엔드 Vercel origin
CLIENT_URL=http://localhost:3000
CLIENT_URL_PROD=https://your-client.vercel.app

# ─── 토스페이먼츠 ─────────────────────────────────────────────────────────────
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_PROFILE_IMAGE_BUCKET=profile-images

# ─── 소셜 로그인 - 카카오 ──────────────────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 설정
# Redirect URI: https://your-server.vercel.app/api/auth/oauth/kakao/callback
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/oauth/kakao/callback

# ─── 소셜 로그인 - 구글 ────────────────────────────────────────────────────────
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
# Redirect URI: https://your-server.vercel.app/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/oauth/google/callback

# ─── AI 단가 분석 (Anthropic Claude) ──────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 에스크로 자동 릴리즈 (기본 7일) ──────────────────────────────────────────
ESCROW_AUTO_RELEASE_DAYS=7

# ─── Seed 전용 ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@freemic.co.kr
ADMIN_PASSWORD="replace-with-admin-password"
