# Database
# Runtime on Vercel or production: Supabase Transaction Pooler URL 권장
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?connection_limit=1"

# Prisma migration/seed: Supabase Direct Connection 또는 Session Pooler URL
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# JWT auth - 최소 32자 이상 랜덤 문자열 사용
JWT_SECRET="replace-with-at-least-32-characters-access-secret"
JWT_REFRESH_SECRET="replace-with-at-least-32-characters-refresh-secret"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Server
PORT=4000
NODE_ENV=development

# Frontend URL allowlist for CORS and Origin checks
CLIENT_URL=http://localhost:3000
CLIENT_URL_PROD=

# Seed-only admin account
ADMIN_EMAIL=admin@freemic.co.kr
ADMIN_PASSWORD="replace-with-admin-password"

# Toss Payments secret key
# 실제 키는 .env에만 넣고, .env.example에는 절대 넣지 마세요.
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx
